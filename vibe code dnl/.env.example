# Backend (Express) environment variables

# MySQL connection
DB_HOST=localhost
DB_USER=root
# XAMPP default: blank password
DB_PASSWORD=
DB_NAME=dispatch_todo_app

# Auth
# IMPORTANT: Set this in production to a long random string.
JWT_SECRET=dev-secret-change-me

# Server
PORT=5000

# Security / deployment
# Comma-separated list of allowed browser origins for CORS.
# Example: CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
# If omitted, CORS is permissive (all origins allowed).
CORS_ORIGIN=

# Admin-only screenshot endpoint
# If set, only these hostnames are allowed for /api/screenshot.
# Example: SCREENSHOT_ALLOWED_HOSTS=app.yourdomain.com
SCREENSHOT_ALLOWED_HOSTS=
